
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Users collection stores roles
    match /users/{userId} {
      // Only admins can read user roles
      allow read: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      // Only admins can write user roles
      allow write: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Portraits collection
    match /portraits/{portraitId} {
      // Anyone can read portraits for the public gallery
      allow read: if true;
      
      // Anyone can vote (update the votes field)
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes']);

      // Any authenticated user can create a portrait
      allow create: if request.auth != null;

      // Only admins can delete portraits
      allow delete: if get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
