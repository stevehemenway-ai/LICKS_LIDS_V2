rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read for the gallery portraits
    match /portraits/{portraitId} {
      allow read: if true;
      allow write: if false; // Writes are only allowed from the admin server
    }

    // Allow admin users to be read by the server
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if false; // Writes should be handled by an admin process
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
