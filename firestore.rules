
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check for admin role
    function isAdmin(userId) {
      return exists(/databases/$(database)/documents/users/$(userId)) &&
             get(/databases/$(database)/documents/users/$(userId)).data.role == 'admin';
    }

    // Rules for the 'portraits' collection
    match /portraits/{portraitId} {
      // Anyone can read (get, list) portraits for the public gallery
      allow read: if true;

      // Only authenticated users can create portraits
      allow create: if request.auth != null;
      
      // Allow anyone to update the 'votes' field
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes']);

      // Only admins can delete portraits
      allow delete: if isAdmin(request.auth.uid);
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Users can only read their own document
      // Admins can read any user document
      allow read: if request.auth.uid == userId || isAdmin(request.auth.uid);

      // Only admins can create, update, or delete user roles
      allow write: if isAdmin(request.auth.uid);
    }
  }
}
