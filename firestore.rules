rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Portraits collection
    match /portraits/{portraitId} {
      // Allow public read for the gallery
      allow get, list;
      
      // Allow server (authenticated) to create portraits and update votes
      allow create, update: if request.auth != null;

      // Allow only admins to delete portraits
      allow delete: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection for role management
    match /users/{userId} {
      // Allow a user to read their own document, or an admin to read any user document
      allow read: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
  }
}
