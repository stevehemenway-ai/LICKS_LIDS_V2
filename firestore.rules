
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /portraits/{portraitId} {
      // Allow anyone to read the gallery portraits
      allow get, list: if true;

      // Only allow the backend to create new portraits
      allow create: if request.auth == null; // Placeholder for server-side-only access

      // Only allow updates to the 'votes' field
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes']);
    }
  }
}
