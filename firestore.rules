rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to portraits for the gallery
    match /portraits/{portraitId} {
      allow read: if true;

      // Allow create, update, delete only from server-side code (no client access)
      allow write: if false; 
    }
    
    // Disallow client-side writes to the users collection for security
    match /users/{userId} {
       allow read, write: if false;
    }
  }
}
