
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check for admin role from Firestore
    function isAdmin() {
      return firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
             firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Match files in the 'portraits' folder
    match /portraits/{imageId} {
      // Anyone can read images, required for public gallery
      allow read: if true;

      // Only authenticated users can create (upload) new images
      allow create: if request.auth != null;

      // Only admins can delete images
      allow delete: if isAdmin();
    }
  }
}
