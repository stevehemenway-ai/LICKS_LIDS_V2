rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This is necessary for the gallery to display images.
    match /{allPaths=**} {
      allow read;
    }

    // Only allow writes to the 'portraits' directory for authenticated users.
    // In the context of this app, the server action is the authenticated "user".
    match /portraits/{allPaths=**} {
      allow write: if request.auth != null;
    }
  }
}
